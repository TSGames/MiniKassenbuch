<?xml version="1.0"?>
<psalm errorLevel="3">
    <projectFiles>
        <directory name="src" />
        <ignoreFiles>
            <directory name="vendor" />
        </ignoreFiles>
    </projectFiles>

    <issueHandlers>
        <UndefinedGlobalVariable>
            <errorLevel type="suppress">
                <file name="src/api_routes.php" />
                <file name="src/routes.php" />
                <file name="src/middleware.php" />
                <file name="src/dependencies.php" />
            </errorLevel>
        </UndefinedGlobalVariable>
        <UndefinedClass>
            <errorLevel type="suppress" />
        </UndefinedClass>
        <UndefinedFunction>
            <errorLevel type="suppress" />
        </UndefinedFunction>
    </issueHandlers>
</psalm>
