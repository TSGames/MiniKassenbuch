<?xml version="1.0"?>
<psalm errorLevel="3">
    <projectFiles>
        <directory name="src" />
        <ignoreFiles>
            <directory name="vendor" />
        </ignoreFiles>
    </projectFiles>

    <issueHandlers>
        <!-- The $app variable is passed to api_routes.php from index.php -->
        <UndefinedGlobalVariable>
            <errorLevel type="suppress">
                <file name="src/api_routes.php" />
                <file name="src/routes.php" />
                <file name="src/middleware.php" />
                <file name="src/dependencies.php" />
            </errorLevel>
        </UndefinedGlobalVariable>

        <!-- Slim framework uses closures with $this context -->
        <InvalidScope>
            <errorLevel type="suppress">
                <file name="src/api_routes.php" />
                <file name="src/routes.php" />
                <file name="src/middleware.php" />
                <file name="src/dependencies.php" />
            </errorLevel>
        </InvalidScope>

        <!-- Slim route handlers use unused parameters -->
        <UnusedClosureParam>
            <errorLevel type="suppress">
                <file name="src/api_routes.php" />
                <file name="src/routes.php" />
            </errorLevel>
        </UnusedClosureParam>

        <!-- Slim's Container uses array access interface -->
        <UndefinedInterfaceMethod>
            <errorLevel type="suppress">
                <file name="src/app.php" />
            </errorLevel>
        </UndefinedInterfaceMethod>

        <!-- str_ireplace with string args always returns string -->
        <PossiblyInvalidArgument>
            <errorLevel type="suppress">
                <file name="src/app.php" />
                <file name="src/dependencies.php" />
            </errorLevel>
        </PossiblyInvalidArgument>

        <!-- PhpRenderer exists in some versions of Slim, suppress for compat -->
        <UndefinedClass>
            <errorLevel type="suppress">
                <file name="src/dependencies.php" />
            </errorLevel>
        </UndefinedClass>

        <!-- addCategory return value is intentionally unused in callers -->
        <PossiblyUnusedReturnValue>
            <errorLevel type="suppress">
                <file name="src/db.php" />
            </errorLevel>
        </PossiblyUnusedReturnValue>

    </issueHandlers>
</psalm>
