Order allow,deny
Allow from all
<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteCond %{REQUEST_URI}::$1 ^(/.+)/(.*)::\2$
  RewriteRule ^(.*) - [E=BASE:%1]

  # Serve static files and directories from browser/ directly
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # API routes go to PHP index.php
  RewriteCond %{REQUEST_URI} ^/api
  RewriteRule ^ index.php [QSA,L]

  # Everything else goes to the Angular app
  RewriteRule ^ browser/index.html [QSA,L]
</IfModule>
